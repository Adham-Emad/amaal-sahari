{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/page",
      "destination": "/",
      "statusCode": 308,
      "regex": "^(?!/_next)/page(?:/)?$"
    }
  ],
  "headers": [
    {
      "source": "/((?!_next/static|_next/image|favicon|uploads|images).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "Expires",
          "value": "0"
        }
      ],
      "regex": "^(?:/((?!_next/static|_next/image|favicon|uploads|images).*))(?:/)?$"
    },
    {
      "source": "/uploads/:file*.mov",
      "headers": [
        {
          "key": "Content-Type",
          "value": "video/quicktime"
        }
      ],
      "regex": "^/uploads(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?\\.mov(?:/)?$"
    },
    {
      "source": "/uploads/:file*.avi",
      "headers": [
        {
          "key": "Content-Type",
          "value": "video/x-msvideo"
        }
      ],
      "regex": "^/uploads(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?\\.avi(?:/)?$"
    },
    {
      "source": "/uploads/:file*.mkv",
      "headers": [
        {
          "key": "Content-Type",
          "value": "video/x-matroska"
        }
      ],
      "regex": "^/uploads(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?\\.mkv(?:/)?$"
    },
    {
      "source": "/uploads/:file*.mp4",
      "headers": [
        {
          "key": "Content-Type",
          "value": "video/mp4"
        }
      ],
      "regex": "^/uploads(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?\\.mp4(?:/)?$"
    },
    {
      "source": "/uploads/:file*.webm",
      "headers": [
        {
          "key": "Content-Type",
          "value": "video/webm"
        }
      ],
      "regex": "^/uploads(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?\\.webm(?:/)?$"
    }
  ],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/blog/[id]",
      "regex": "^/blog/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/blog/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/case-studies/[id]",
      "regex": "^/case\\-studies/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/case\\-studies/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
